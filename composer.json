{
	"name": "hypejunction/hypeicons",
	"type": "elgg-plugin",
	"description": "Interface for uploading and cropping entity icons and covers",
	"homepage": "https://github.com/hypeJunction/hypeIcons",
	"keywords": [
		"elgg",
		"plugin",
		"icon",
		"cover",
		"avatar",
		"cropper"
	],
	"license": "GPL-2.0",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "ismayil.khayredinov@gmail.com"
		}
	],
	"extra": {
		"elgg-plugin": {
			"id": "hypeicons"
		}
	},
	"require": {
		"php": ">=8.2",
		"composer/installers": "^2.0",
		"elgg/elgg": "~6.1.0",
		"bower-asset/cropper": "~2.1"
	},
	"conflict": {
		"elgg/elgg": "<6.0"
	},
	"autoload": {
		"psr-4": {
			"hypeJunction\\Icons\\": "classes/hypeJunction/Icons/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	}
}
